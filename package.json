{
  "name": "steganography-mcp",
  "version": "0.2.0",
  "description": "Steganography analysis MCP server — 128 tools, 17 categories. Image steganalysis, JPEG/F5/JSteg detection, audio steganography, video stego, GIF palette analysis, network covert channels, MP3 stego, spread spectrum, BPCS, archive stego, QR code analysis, text steganography, file forensics, document analysis, encoding detection. 100% local, zero API keys required.",
  "type": "module",
  "bin": {
    "steganography-mcp": "dist/index.js"
  },
  "files": ["dist/"],
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp", "model-context-protocol", "steganography", "steganalysis",
    "lsb", "image-forensics", "audio-steganography", "text-steganography",
    "zero-width-characters", "file-forensics", "binwalk", "entropy-analysis",
    "chi-square", "ctf", "capture-the-flag", "digital-forensics",
    "jpeg-analysis", "f5-stego", "jsteg", "outguess", "bpcs",
    "video-steganography", "gif-steganography", "network-steganography",
    "mp3-steganography", "spread-spectrum", "archive-steganography",
    "qr-code", "pcap", "covert-channel", "watermark",
    "exif", "metadata", "security",
    "cybersecurity", "infosec", "ai", "ai-agent", "claude", "llm"
  ],
  "author": "Orhan Yildirim <contact@orhanyildirim.us> (https://orhanyildirim.us)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/badchars/steganography-mcp.git"
  },
  "homepage": "https://www.npmjs.com/package/steganography-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4",
    "pngjs": "^7.0.0",
    "jpeg-js": "^0.4.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.15.3",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.8.2"
  }
}
