{
  "name": "steganography-mcp",
  "version": "0.1.0",
  "description": "Steganography analysis MCP server — 60 tools for image steganalysis, audio steganography, text steganography, file forensics, JPEG analysis, document analysis, encoding detection. 100% local, zero API keys required.",
  "type": "module",
  "bin": {
    "steganography-mcp": "dist/index.js"
  },
  "files": ["dist/"],
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp", "model-context-protocol", "steganography", "steganalysis",
    "lsb", "image-forensics", "audio-steganography", "text-steganography",
    "zero-width-characters", "file-forensics", "binwalk", "entropy-analysis",
    "chi-square", "ctf", "capture-the-flag", "digital-forensics",
    "jpeg-analysis", "exif", "metadata", "security",
    "cybersecurity", "infosec", "ai", "ai-agent", "claude", "llm"
  ],
  "author": "Orhan Yildirim <contact@orhanyildirim.us> (https://orhanyildirim.us)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/badchars/steganography-mcp.git"
  },
  "homepage": "https://www.npmjs.com/package/steganography-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4",
    "pngjs": "^7.0.0",
    "jpeg-js": "^0.4.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.15.3",
    "@types/pngjs": "^6.0.5",
    "typescript": "^6.0.3"
  }
}
